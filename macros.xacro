<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="box_inertia" params="m x y z">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${m}"/>
            <inertia ixx="${(1/12) * m * (y*y + z*z)}" ixy="0" ixz="0"
                     iyy="${(1/12) * m * (x*x + z*z)}" iyz="0"
                     izz="${(1/12) * m * (x*x + y*y)}"/>
        </inertial>
    </xacro:macro>

    <xacro:macro name="cylinder_inertia" params="m r h">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${m}"/>
            <inertia ixx="${(1/12) * m * (3*r*r + h*h)}" ixy="0" ixz="0"
                     iyy="${(1/12) * m * (3*r*r + h*h)}" iyz="0"
                     izz="${(1/2) * m * r*r}"/>
        </inertial>
    </xacro:macro>

    <xacro:macro name="sphere_inertia" params="m r">
        <inertial>
            <mass value="${m}"/>
            <inertia ixx="${(2/5) * m * r*r}" ixy="0" ixz="0"
                     iyy="${(2/5) * m * r*r}" iyz="0"
                     izz="${(2/5) * m * r*r}"/>
        </inertial>
    </xacro:macro>

    <xacro:macro name="drive_wheel" params="prefix reflect">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
                </geometry>
                <material name="black"/>
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
                </geometry>
            </collision>
            <xacro:cylinder_inertia m="0.1" r="${wheel_radius}" h="${wheel_width}"/>
        </link>

        <joint name="${prefix}_wheel_joint" type="continuous">
            <parent link="base_link"/>
            <child link="${prefix}_wheel_link"/>
            <origin xyz="0 ${reflect * wheel_y_offset} ${wheel_z_offset}" rpy="${-PI/2} 0 0"/>
            <axis xyz="0 0 1"/>
        </joint>
    </xacro:macro>

</robot>
